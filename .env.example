# Email Agent Configuration
# Copy to .env and fill in values

# GCP Project ID (required for Gmail API + PubSub)
GCP_PROJECT_ID=

# Agent Mode: "all-agents" | "hybrid" | "direct-api"
AGENT_MODE=all-agents

# Preferred Agent: "claude" | "codex" | "gemini"
PREFERRED_AGENT=claude

# Direct API keys (only needed for "hybrid" or "direct-api" modes)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Embedding provider: "openai" | "openrouter" | "local"
EMBEDDING_PROVIDER=openai

# OpenRouter (for embeddings + LLM access via openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-8b

# Webhook URLs (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Data directory (defaults to ~/.email-agent/data)
DATA_DIR=
